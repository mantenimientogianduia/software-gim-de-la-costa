{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role, membership status and QR DNI",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "dni": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "instructor", "socio"] },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "membershipValidUntil": { "type": "object", "description": "Firestore Timestamp" },
        "lastPaymentDate": { "type": "object", "description": "Firestore Timestamp" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["email", "role", "status"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "Monthly fee payment records",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User email" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "concept": { "type": "string" },
        "monthsPaid": { "type": "number" },
        "paymentDate": { "type": "object" },
        "validUntil": { "type": "object" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "amount", "validUntil"]
    },
    "TrainingPlan": {
      "title": "Training Plan",
      "description": "Set of weeks and exercises for a user or template",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["template", "assignment"] },
        "userId": { "type": "string" },
        "instructorId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed", "archived"] },
        "weeksCount": { "type": "number" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "startDate": { "type": "object" },
        "tags": { "type": "array" }
      }
    },
    "TrainingWeek": {
      "title": "Training Week",
      "description": "A week of training within a plan",
      "type": "object",
      "properties": {
        "planId": { "type": "string" },
        "order": { "type": "number" },
        "type": { "type": "string", "enum": ["base", "deload", "peak", "test"] },
        "goal": { "type": "string" },
        "days": { "type": "array" }
      }
    },
    "WorkoutSession": {
      "title": "Workout Session",
      "description": "Log of a performed workout",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "weekOrder": { "type": "number" },
        "dayOrder": { "type": "number" },
        "date": { "type": "object" },
        "duration": { "type": "number" },
        "feeling": { "type": "string" },
        "energy": { "type": "number" },
        "exercises": { "type": "array" },
        "notes": { "type": "string" }
      }
    },
    "GymClass": {
      "title": "Gym Class",
      "description": "Scheduled group class",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "instructorId": { "type": "string" },
        "startTime": { "type": "object" },
        "endTime": { "type": "object" },
        "capacity": { "type": "number" },
        "enrolledCount": { "type": "number" },
        "status": { "type": "string", "enum": ["scheduled", "cancelled", "completed"] }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "User reservation for a class",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] },
        "createdAt": { "type": "object" }
      }
    },
    "Attendance": {
      "title": "Attendance record",
      "description": "Check-in/out records for gym access",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "checkIn": { "type": "object" },
        "checkOut": { "type": "object" },
        "status": { "type": "string", "enum": ["present", "completed"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Global user profiles" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Financial records" },
    "/training_plans/{planId}": { "schema": "TrainingPlan", "description": "Training templates and assignments" },
    "/training_weeks/{weekId}": { "schema": "TrainingWeek", "description": "Weeks belonging to a plan" },
    "/workout_sessions/{sessionId}": { "schema": "WorkoutSession", "description": "User exercise logs" },
    "/classes/{classId}": { "schema": "GymClass", "description": "Class schedule" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Class reservations" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Access logs" },
    "/exercises/{exerciseId}": { "schema": { "type": "object" }, "description": "Master list of exercises" }
  }
}
