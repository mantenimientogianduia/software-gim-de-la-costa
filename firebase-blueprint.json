{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about gym members, teachers, and admins",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "profesor", "socio"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "firstName", "lastName", "status"]
    },
    "Routine": {
      "title": "Workout Routine",
      "description": "Assigned workout plans for socios",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Email of the member" },
        "instructorId": { "type": "string", "description": "Email of the teacher" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "sets": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "instructorId", "title", "exercises"]
    },
    "Class": {
      "title": "Gym Class",
      "description": "Scheduled classes like Crossfit, Yoga, etc.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "instructorId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "capacity": { "type": "integer" },
        "enrolledCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "cancelled"] }
      },
      "required": ["title", "instructorId", "startTime", "endTime", "capacity", "enrolledCount"]
    },
    "Booking": {
      "title": "Class Booking",
      "description": "Record of a member attending a class",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "userId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Profile information for all users"
    },
    "/routines/{routineId}": {
      "schema": "Routine",
      "description": "Workout routines assigned to users"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Available gym classes"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User class registrations"
    }
  }
}
