{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User specific data including streaks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "currentStreak": { "type": "number" },
        "maxStreak": { "type": "number" },
        "lastActivityDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "TrainingSession": {
      "title": "Training Session",
      "description": "A recorded training day",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["training", "rest"] }
      },
      "required": ["date", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user documents"
    },
    "/users/{userId}/history/{date}": {
      "schema": "TrainingSession",
      "description": "Daily training status records"
    }
  }
}
