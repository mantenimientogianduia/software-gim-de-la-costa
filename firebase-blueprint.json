{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the system",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "profesor", "socio"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "pending"] },
        "atGym": { "type": "boolean" },
        "currentActivity": { "type": "string" },
        "lastCheckIn": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "firstName", "lastName", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Log of user attendance at the gym",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "checkInAt": { "type": "string", "format": "date-time" },
        "checkOutAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "completed"] }
      },
      "required": ["userId", "checkInAt", "status"]
    },
    "TrainingPlan": {
      "title": "TrainingPlan",
      "description": "Workout plan structure",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["template", "assignment"] },
        "userId": { "type": "string" },
        "instructorId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "completed", "archived"] },
        "weeksCount": { "type": "integer" },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "startDate": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "instructorId", "status"]
    },
    "Class": {
      "title": "Class",
      "description": "Gym class schedule",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "instructorId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "capacity": { "type": "integer" },
        "enrolledCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "cancelled"] }
      },
      "required": ["title", "instructorId", "startTime", "endTime", "capacity", "enrolledCount"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "System users" },
    "attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance logs" },
    "training_plans/{planId}": { "schema": "TrainingPlan", "description": "Training plans" },
    "classes/{classId}": { "schema": "Class", "description": "Scheduled classes" }
  }
}
