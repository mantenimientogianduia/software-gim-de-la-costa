rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && (data.currentStreak is number && data.currentStreak >= 0)
        && (data.maxStreak is number && data.maxStreak >= 0);
    }

    // Validation for TrainingSession
    function isValidSession(data) {
      return data.date is string && data.date.size() == 10
        && data.type in ['training', 'rest'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['currentStreak', 'maxStreak', 'lastActivityDate', 'displayName']);

      match /history/{date} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSession(incoming());
      }
    }
  }
}
