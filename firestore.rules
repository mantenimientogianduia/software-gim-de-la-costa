rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS (Phase 3) ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isUserEmail(email) { return isSignedIn() && request.auth.token.email == email; }
    
    // Bootstrap Admin: gino.pieretti00@gmail.com
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'gino.pieretti00@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isInstructor() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isInstructor());
      allow list: if isAdmin() || isInstructor(); // Only staff can browse users
      
      function isValidUser(data) {
        return data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'instructor', 'socio'] &&
               data.status in ['active', 'inactive', 'pending'] &&
               (!('dni' in data) || (data.dni is string && data.dni.size() <= 20));
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                     incoming().role == 'socio' && incoming().status == 'pending' &&
                     incoming().createdAt == request.time;
      
      allow update: if (isAdmin() && isValidUser(incoming())) || (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'dni', 'updatedAt']) &&
        incoming().updatedAt == request.time
      );
    }

    // --- PAYMENTS ---
    match /payments/{paymentId} {
      allow get: if isSignedIn() && (isUserEmail(existing().userId) || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.token.email);
      
      function isValidPayment(data) {
        return data.userId is string && data.amount is number && data.amount > 0 &&
               data.status in ['confirmed', 'pending', 'cancelled'] &&
               data.createdAt == request.time;
      }
      
      allow create: if isAdmin() && isValidPayment(incoming());
      allow update: if isAdmin() && isValidPayment(incoming()) &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    // --- TRAINING PLANS ---
    match /training_plans/{planId} {
      allow read: if isSignedIn(); // Templates are public for staff/members
      
      function isValidPlan(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.type in ['template', 'assignment'] &&
               data.status in ['draft', 'active', 'completed', 'archived'];
      }

      allow create: if (isAdmin() || isInstructor()) && isValidPlan(incoming());
      allow update: if (isAdmin() || isInstructor()) && isValidPlan(incoming());
      allow delete: if isAdmin();
    }

    // --- TRAINING WEEKS ---
    match /training_weeks/{weekId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // --- WORKOUT SESSIONS ---
    match /workout_sessions/{sessionId} {
      allow read: if isSignedIn() && (isUserEmail(resource.data.userId) || isAdmin() || isInstructor());
      
      function isValidSession(data) {
        return data.userId is string && data.planId is string &&
               data.exercises is list && data.exercises.size() <= 50;
      }

      allow create: if isSignedIn() && isUserEmail(incoming().userId) && isValidSession(incoming());
    }

    // --- CLASSES & BOOKINGS ---
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isUserEmail(resource.data.userId) || isAdmin() || isInstructor());
      
      allow create: if isSignedIn() && isUserEmail(incoming().userId) && 
                     exists(/databases/$(database)/documents/classes/$(incoming().classId));
      
      allow update: if isAdmin() || (isUserEmail(existing().userId) && incoming().status == 'cancelled');
    }

    // --- ACCESS/ATTENDANCE ---
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isInstructor() || (isSignedIn() && isUserEmail(resource.data.userId));
      allow create: if isAdmin(); // Check-in is handled by local machine/admin
      allow update: if isAdmin() || (isSignedIn() && isUserEmail(existing().userId) && 
                                     incoming().diff(existing()).affectedKeys().hasOnly(['checkOut', 'status']));
    }

    // --- EXERCISES MASTER ---
    match /exercises/{exerciseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }
  }
}
